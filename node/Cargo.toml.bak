[package]
name = "node"
version = "0.1.0"
edition = "2021"

[dependencies]
# Tokio with io-util and sync features (needed for BufReader, AsyncRead/WriteExt, mpsc)
tokio = { version = "1", features = ["rt-multi-thread", "macros", "time", "net", "io-util", "sync"] }

serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
toml = "0.7"
log = "0.4"
env_logger = "0.10"
anyhow = "1.0"
clap = { version = "4.3", features = ["derive"] }
hex = "0.4"
sha2 = "0.10"

# vrf is a workspace crate; default-features = false so features are opt-in from the top-level crate
vrf = { path = "../vrf", default-features = false }

# local workspace crates
consensus = { path = "../consensus" }
mempool = { path = "../mempool" }
state = { path = "../state" }

[features]
# enable Ristretto VRF via node feature `r255`
r255 = ["vrf/r255"]
